generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountSize {
  SIZE_10K
  SIZE_25K
  SIZE_50K
  SIZE_100K
  SIZE_200K
}

enum ChallengeStep {
  STEP_1
  STEP_2
}

enum RoomPublicStatus {
  PUBLIC
  HIDDEN
}

enum RoomLifecycleStatus {
  SIGNUP_OPEN
  READY_TO_START
  AWAITING_DECISION
  ACTIVE
  EXPIRED
  COMPLETED
  ARCHIVED
}

enum ApplicantStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  INVITATION_SENT
  JOINED
  REJECTED
}

enum JobType {
  SCHEDULED_ROOM_UPDATE
  MANUAL_TRADER_REFRESH
  MANUAL_ROOM_REFRESH
  ROOM_STATUS_SYNC
}

enum JobStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

enum FetchSource {
  SCHEDULER
  MANUAL
  API
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
}

enum NotificationKind {
  ROOM_INVITATION
  ROOM_READY
  GENERAL_UPDATE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum CourseAccessLevel {
  BASIC
  TRADING_PLAN
  INTERMEDIATE
  ADVANCED
  FULL_ADVANCED
}

enum PaymentProvider {
  MANUAL
}

enum PaymentStatus {
  PENDING_SUBMISSION
  PENDING_CONFIRMATION
  CONFIRMED
  CANCELLED
}

enum PackageEnrollmentStatus {
  PENDING_PAYMENT
  PENDING_CONFIRMATION
  ENROLLED
  AWAITING_DECISION
  MERGED
  CANCELLED
}

enum EnrollmentDecisionChoice {
  MERGE
  WAIT
}

enum ResourceType {
  STRATEGY
  INDICATOR
  TOOL
}

enum EnrollmentAuditType {
  CREATED
  PAYMENT_SUBMITTED
  PAYMENT_CONFIRMED
  ROOM_ASSIGNED
  ROOM_MOVED
  ROOM_MERGED
  WAIT_SELECTED
  MERGE_SELECTED
  CANCELLED
  NOTE
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime?
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ChallengeRoom {
  id                  String              @id @default(cuid())
  title               String
  slug                String              @unique
  description         String?
  accountSize         AccountSize
  step                ChallengeStep
  entryFeeUsd         Float               @default(0)
  startDate           DateTime
  endDate             DateTime
  publicStatus        RoomPublicStatus    @default(PUBLIC)
  lifecycleStatus     RoomLifecycleStatus @default(ACTIVE)
  maxTraderCapacity   Int                 @default(10)
  updateTimes         String[]            @default([])
  updateTimezone      String              @default("Asia/Ulaanbaatar")
  allowExpiredUpdates Boolean             @default(false)
  leaderTraderId      String?
  winnerTraderId      String?
  winnerDeclaredAt    DateTime?
  isPackageRoom       Boolean             @default(false)
  packageTierId       String?
  roomSequence        Int?
  decisionDeadlineAt  DateTime?
  mergeTargetRoomId   String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  applicants          Applicant[]
  traders             Trader[]
  jobLogs             JobRunLog[]
  notifications       NotificationDispatch[]
  packageEnrollments  PackageEnrollment[]
  packageTier         PackageTier?        @relation(fields: [packageTierId], references: [id], onDelete: SetNull)
  mergeTargetRoom     ChallengeRoom?      @relation("PackageRoomMergeTarget", fields: [mergeTargetRoomId], references: [id], onDelete: SetNull)
  mergedSourceRooms   ChallengeRoom[]     @relation("PackageRoomMergeTarget")
  auditLogMovesFrom   EnrollmentAuditLog[] @relation("EnrollmentAuditFromRoom")
  auditLogMovesTo     EnrollmentAuditLog[] @relation("EnrollmentAuditToRoom")
  leaderTrader        Trader?             @relation("RoomLeader", fields: [leaderTraderId], references: [id], onDelete: SetNull)
  winnerTrader        Trader?             @relation("RoomWinner", fields: [winnerTraderId], references: [id], onDelete: SetNull)

  @@index([lifecycleStatus, startDate])
  @@index([accountSize, step])
  @@index([isPackageRoom, packageTierId, lifecycleStatus])
  @@index([packageTierId, roomSequence])
  @@unique([packageTierId, roomSequence])
}

model Trader {
  id                    String          @id @default(cuid())
  roomId                String
  fullName              String
  metrixUrl             String          @unique
  active                Boolean         @default(true)
  currentProfitPercent  Float           @default(0)
  currentProfitAbsolute Float?
  currentDailyLossValue Float?
  currentMaxLossValue   Float?
  currentBalance        Float?
  currentEquity         Float?
  violationFlag         Boolean         @default(false)
  violationReason       String?
  completionRecorded    Boolean         @default(false)
  rank                  Int?
  latestSnapshotAt      DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  room                  ChallengeRoom   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  snapshots             TraderSnapshot[]
  jobLogs               JobRunLog[]
  leadingRooms          ChallengeRoom[] @relation("RoomLeader")
  winningRooms          ChallengeRoom[] @relation("RoomWinner")

  @@unique([roomId, fullName])
  @@index([roomId, rank])
}

model TraderSnapshot {
  id            String   @id @default(cuid())
  traderId      String
  fetchedAt     DateTime @default(now())
  profitPercent Float
  profitAbsolute Float?
  dailyLossValue Float?
  maxLossValue   Float?
  balance        Float?
  equity         Float?
  statusNotes    String?
  rawPayload     Json?
  trader         Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId, fetchedAt])
}

model Applicant {
  id                 String               @id @default(cuid())
  roomId             String?
  clerkUserId        String?
  fullName           String
  email              String
  phoneNumber        String
  telegramUsername   String?
  desiredAccountSize AccountSize
  note               String?
  status             ApplicantStatus      @default(PENDING)
  invitationSentAt   DateTime?
  joinedAt           DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  room               ChallengeRoom?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  notifications      NotificationDispatch[]

  @@index([desiredAccountSize, status])
  @@index([clerkUserId, desiredAccountSize, status])
  @@index([roomId, status])
  @@index([email, createdAt])
}

model NotificationDispatch {
  id           String             @id @default(cuid())
  roomId       String?
  applicantId  String?
  channel      NotificationChannel
  kind         NotificationKind
  recipient    String
  subject      String?
  message      String
  status       NotificationStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime           @default(now())
  room         ChallengeRoom?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  applicant    Applicant?         @relation(fields: [applicantId], references: [id], onDelete: SetNull)

  @@index([channel, status, createdAt])
}

model JobRunLog {
  id          String        @id @default(cuid())
  roomId      String?
  traderId    String?
  jobType     JobType
  source      FetchSource   @default(SCHEDULER)
  status      JobStatus
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  scheduledFor DateTime?
  attempt     Int           @default(1)
  message     String?
  details     Json?
  room        ChallengeRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  trader      Trader?        @relation(fields: [traderId], references: [id], onDelete: SetNull)

  @@index([status, startedAt])
  @@index([roomId, startedAt])
  @@index([traderId, startedAt])
}

model AppSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubmissionAttempt {
  id        String   @id @default(cuid())
  route     String
  ipAddress String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([route, ipAddress, createdAt])
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([sortOrder, name])
}

model BlogPopup {
  id          String     @id @default(cuid())
  title       String
  body        String
  imageUrl    String?
  videoUrl    String?
  ctaLabel    String
  ctaUrl      String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([isActive, updatedAt])
}

model BlogPost {
  id                       String         @id @default(cuid())
  title                    String
  slug                     String         @unique
  excerpt                  String
  bodyMarkdown             String
  coverImageUrl            String
  categoryId               String
  status                   BlogPostStatus @default(DRAFT)
  publishedAt              DateTime?
  requiresLoginForFullRead Boolean        @default(false)
  showEndPopup             Boolean        @default(false)
  popupId                  String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  category                 BlogCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  popup                    BlogPopup?     @relation(fields: [popupId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([categoryId, publishedAt])
}

model PackageTier {
  id                 String               @id @default(cuid())
  slug               String               @unique
  nameMn             String
  accountSize        AccountSize          @unique
  priceUsd           Float
  maxUsers           Int                  @default(10)
  featuresMn         String[]             @default([])
  strategyCount      Int                  @default(0)
  includesCoaching   Boolean              @default(false)
  coachingHours      Int                  @default(0)
  includesIndicators Boolean              @default(false)
  courseAccessLevel  CourseAccessLevel
  prioritySupport    Boolean              @default(false)
  sortOrder          Int                  @default(0)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  rooms              ChallengeRoom[]
  courses            CoursePackageTier[]
  resources          ResourcePackageTier[]
  payments           PaymentRecord[]
  enrollments        PackageEnrollment[]

  @@index([isActive, sortOrder])
}

model PaymentRecord {
  id                  String         @id @default(cuid())
  clerkUserId         String
  packageTierId       String
  customerName        String?
  customerEmail       String?
  provider            PaymentProvider @default(MANUAL)
  status              PaymentStatus   @default(PENDING_SUBMISSION)
  amountUsd           Float
  currency            String          @default("USD")
  reference           String?
  proofNote           String?
  proofUrl            String?
  metadata            Json?
  submittedAt         DateTime?
  confirmedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  packageTier         PackageTier       @relation(fields: [packageTierId], references: [id], onDelete: Restrict)
  enrollment          PackageEnrollment?

  @@index([clerkUserId, createdAt])
  @@index([status, createdAt])
  @@index([packageTierId, createdAt])
}

model PackageEnrollment {
  id             String                   @id @default(cuid())
  clerkUserId    String
  packageTierId  String
  roomId         String?
  paymentId      String?                  @unique
  status         PackageEnrollmentStatus  @default(PENDING_PAYMENT)
  decisionChoice EnrollmentDecisionChoice?
  unlockedAt     DateTime?
  decidedAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  packageTier    PackageTier              @relation(fields: [packageTierId], references: [id], onDelete: Restrict)
  room           ChallengeRoom?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  payment        PaymentRecord?           @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  progress       CourseProgress[]
  auditLogs      EnrollmentAuditLog[]

  @@index([clerkUserId, createdAt])
  @@index([clerkUserId, status, createdAt])
  @@index([roomId, status])
  @@index([packageTierId, status])
}

model Course {
  id            String             @id @default(cuid())
  slug          String             @unique
  titleMn       String
  descriptionMn String?
  videoUrl      String?
  textContent   String?
  pdfUrls       String[]           @default([])
  sortOrder     Int                @default(0)
  isPublished   Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  packageAccess CoursePackageTier[]
  progress      CourseProgress[]

  @@index([isPublished, sortOrder])
}

model CoursePackageTier {
  courseId      String
  packageTierId String
  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  packageTier   PackageTier @relation(fields: [packageTierId], references: [id], onDelete: Cascade)

  @@id([courseId, packageTierId])
}

model Resource {
  id            String                @id @default(cuid())
  titleMn       String
  descriptionMn String?
  type          ResourceType
  linkUrl       String
  sortOrder     Int                   @default(0)
  isPublished   Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  packageAccess ResourcePackageTier[]

  @@index([type, isPublished, sortOrder])
}

model ResourcePackageTier {
  resourceId    String
  packageTierId String
  resource      Resource    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  packageTier   PackageTier @relation(fields: [packageTierId], references: [id], onDelete: Cascade)

  @@id([resourceId, packageTierId])
}

model CourseProgress {
  id              String            @id @default(cuid())
  clerkUserId     String
  courseId        String
  enrollmentId    String?
  percentComplete Int               @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment      PackageEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@unique([clerkUserId, courseId])
  @@index([enrollmentId])
}

model EnrollmentAuditLog {
  id          String              @id @default(cuid())
  enrollmentId String
  type        EnrollmentAuditType
  message     String
  actorId     String?
  fromRoomId  String?
  toRoomId    String?
  createdAt   DateTime            @default(now())
  enrollment  PackageEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  fromRoom    ChallengeRoom?      @relation("EnrollmentAuditFromRoom", fields: [fromRoomId], references: [id], onDelete: SetNull)
  toRoom      ChallengeRoom?      @relation("EnrollmentAuditToRoom", fields: [toRoomId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, createdAt])
}
